# ============================================================
# findMe — Variables d'environnement
# Copiez ce fichier en .env et ajustez les valeurs
# ============================================================

# ----------------------------------------------------------
# API Base URL — Routes Nitro locales (pas de backend externe)
# ----------------------------------------------------------
NUXT_PUBLIC_API_BASE=/api

# ----------------------------------------------------------
# Resend — Email transactionnel (réinitialisation de mot de passe)
# Créez un compte gratuit sur https://resend.com/ et obtenez votre clé API
# Gratuit : 100 emails/jour, 3 000/mois, sans carte bancaire
# Si laissé vide, le code OTP s'affiche directement à l'écran (mode dev)
# ----------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
